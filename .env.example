# Copy this to .env and fill in your values
# cp .env.example .env

# ── Database ────────────────────────────────────────────────
POSTGRES_PASSWORD=supersecretdbpassword

# ── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=supersecretredispassword

# ── Auth ────────────────────────────────────────────────────
NEXTAUTH_SECRET=helloworld@1345+

# GitHub OAuth (from https://github.com/settings/developers)
GitHub_ClientId=your_github_client_id
GitHub_ClientSecret=your_github_client_secret

# Google OAuth (from https://console.cloud.google.com)
Google_ClientId=your_google_client_id
Google_ClientSecret=your_google_client_secret

# ── URLs ─────────────────────────────────────────────────────
# Local dev: use localhost
# On a server: replace localhost with your server IP or domain

NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_HTTP_BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_WS_BACKEND_URL=ws://localhost:8080
